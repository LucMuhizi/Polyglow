---
import Icon from "@/components/ui/Icon.astro"

interface Props {
  categories: Array<{ slug: string; label: string }>
  allLabel?: string
  targetSelector?: string
}

const {
  categories,
  allLabel = "All essays",
  targetSelector = "[data-post-grid]",
} = Astro.props

const slugAttribute = "data-post-category"
const allChipId = "__all"
---

<div
  class="flex flex-wrap items-center gap-2"
  data-category-chips
  data-target={targetSelector}
  data-slug-attr={slugAttribute}
  role="toolbar"
  aria-label="Filter essays by category"
>
  <p class="eyebrow mr-1">Filter</p>
  <button
    type="button"
    class="chip"
    data-category-value={allChipId}
    aria-pressed="true"
  >
    {allLabel}
  </button>
  {
    categories.map((category) => (
      <button
        type="button"
        class="chip"
        data-category-value={category.slug}
        aria-pressed="false"
      >
        {category.label}
      </button>
    ))
  }
  <span class="ml-auto hidden items-center gap-1 text-xs sm:inline-flex" data-category-count-wrap>
    <span data-category-count></span>
    <span class="opacity-75">essays match</span>
  </span>
  <button
    type="button"
    class="chip hidden sm:inline-flex"
    data-category-clear
    hidden
  >
    <Icon name="x" class="size-3.5" dataIcon="inline-start" />
    <span>Clear filter</span>
  </button>
</div>

<script is:inline>
  ;(() => {
    const cleanupKey = "__categoryChipsCleanup"
    window[cleanupKey]?.()

    const ALL = "__all"

    const updateCount = (visible) => {
      document.querySelectorAll("[data-category-count]").forEach((node) => {
        if (node instanceof HTMLElement) node.textContent = String(visible)
      })
      document.querySelectorAll("[data-category-count-wrap]").forEach((node) => {
        if (node instanceof HTMLElement) {
          node.classList.toggle("hidden", visible === 0)
        }
      })
      document.querySelectorAll("[data-category-clear]").forEach((node) => {
        if (node instanceof HTMLElement) node.hidden = visible === 0
      })
    }

    const applyFilter = (value) => {
      document.querySelectorAll("[data-category-chips]").forEach((root) => {
        if (!(root instanceof HTMLElement)) return
        const target = root.dataset.target
        const slugAttr = root.dataset.slugAttr || "data-post-category"
        const grid = target ? document.querySelector(target) : null
        if (!(grid instanceof HTMLElement)) return
        const cards = Array.from(grid.querySelectorAll(`[${slugAttr}]`))
        let visible = 0
        for (const card of cards) {
          const cat = card.getAttribute(slugAttr) || ""
          const match = value === ALL || cat === value
          card.toggleAttribute("hidden", !match)
          if (match) visible += 1
        }
        root.querySelectorAll("[data-category-value]").forEach((button) => {
          if (!(button instanceof HTMLElement)) return
          button.setAttribute(
            "aria-pressed",
            button.dataset.categoryValue === value ? "true" : "false"
          )
        })
        updateCount(visible)
      })
    }

    const handleClick = (event) => {
      const target = event.target
      if (!(target instanceof Element)) return
      const button = target.closest("[data-category-value]")
      if (button instanceof HTMLElement) {
        applyFilter(button.dataset.categoryValue || ALL)
        return
      }
      const clear = target.closest("[data-category-clear]")
      if (clear instanceof HTMLElement) {
        applyFilter(ALL)
      }
    }

    document.addEventListener("click", handleClick)
    document.addEventListener("astro:page-load", () => applyFilter(ALL))

    window[cleanupKey] = () => {
      document.removeEventListener("click", handleClick)
    }
  })()
</script>
