---
import { getCollection, render } from "astro:content"
import Layout from "@/layouts/main.astro"
import ProseContent from "@/components/layout/ProseContent.astro"
import OptimizedPicture from "@/components/features/OptimizedPicture.astro"
import { postPath, postSlug } from "@/utils/posts"
import { getAuthor } from "@/utils/content"
import { getCategory } from "@/config/taxonomy"
import { SITE_CONFIG } from "@/config/site"

export async function getStaticPaths() {
  const posts = await getCollection(
    "post",
    (entry) => !entry.data.draft && entry.data.locale === "en"
  )
  return posts.map((post) => ({
    params: { slug: postSlug(post) },
    props: { post },
  }))
}

const { post } = Astro.props
const { Content, headings } = await render(post)
const author = await getAuthor(post.data.locale, post.data.authors[0])
const path = postPath(post)
const fallbackAuthor = author?.data?.name ?? SITE_CONFIG.name
const categorySlug = (post.data.category ?? "").toString().trim().toLowerCase().replace(/\s+/g, "-")
const category = getCategory(categorySlug) ?? null
const categoryLabel = category?.labelByLocale?.[post.data.locale] ?? categorySlug
const dateFormatter = new Intl.DateTimeFormat("en", {
  month: "short",
  day: "numeric",
  year: "numeric",
})
const publishedLabel = dateFormatter.format(post.data.pubDate)
const titleByLocale: Record<string, string> = {
  en: "Contents",
}
const tocTitle = titleByLocale[post.data.locale] ?? "Contents"
const tocHeadings = (headings ?? [])
  .filter((h) => h.depth === 2 || h.depth === 3)
  .map((h) => ({ depth: h.depth as 2 | 3, text: h.text, slug: h.slug }))
---

<Layout
  lang="en"
  path={path}
  title={post.data.title}
  description={post.data.description}
  image={post.data.heroImage}
  imageAlt={post.data.heroImageAlt}
  ogType="article"
>
  <article class="mx-auto w-full max-w-3xl px-4 py-8 sm:px-5 md:px-6" data-pagefind-body>
    <header class="mb-8">
      <p class="text-xs font-semibold tracking-[0.18em] text-muted-foreground uppercase">
        {categoryLabel}
      </p>
      <h1 class="mt-3 text-balance text-3xl font-semibold leading-tight tracking-tight sm:text-4xl">
        {post.data.title}
      </h1>
      <p class="mt-3 text-sm text-muted-foreground">
        <time datetime={post.data.pubDate.toISOString()}>{publishedLabel}</time>
        <span aria-hidden="true"> · </span>
        <span>{fallbackAuthor}</span>
      </p>
    </header>

    {
      post.data.heroImage && (
        <figure class="mb-8 overflow-hidden rounded-3xl">
          <OptimizedPicture
            src={post.data.heroImage}
            alt={post.data.heroImageAlt ?? post.data.title}
            width={post.data.heroImageWidth}
            height={post.data.heroImageHeight}
            priority
            class="h-auto w-full object-cover"
          />
        </figure>
      )
    }

    <ProseContent class="article-prose max-w-none">
      <Content />
    </ProseContent>

    <footer class="mt-12 border-t border-border pt-6 text-sm text-muted-foreground">
      <p class="text-xs tracking-wide uppercase">Tags</p>
      <p class="mt-2 flex flex-wrap gap-2 text-xs">
        {(post.data.tags ?? []).map((tag) => (
          <span class="rounded-full bg-muted px-2 py-1 text-foreground">{tag}</span>
        ))}
      </p>
    </footer>
  </article>

  {tocHeadings.length >= 3 && (
    <aside class="mx-auto mt-4 hidden max-w-3xl px-4 text-sm text-muted-foreground xl:block">
      <p class="mb-2 font-semibold text-foreground">{tocTitle}</p>
      <ul class="flex flex-col gap-1">
        {tocHeadings.map((h) => (
          <li class:list={[h.depth === 3 ? "pl-3 text-xs" : ""]}>
            <a class="hover:text-foreground" href={`#${h.slug}`}>{h.text}</a>
          </li>
        ))}
      </ul>
    </aside>
  )}
</Layout>
