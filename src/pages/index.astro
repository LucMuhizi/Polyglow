---
import Layout from "@/layouts/main.astro"
import EditorialHero from "@/components/cards/EditorialHero.astro"
import ServiceCard from "@/components/cards/ServiceCard.astro"
import ProfileCard from "@/components/cards/ProfileCard.astro"
import PostGrid from "@/components/lists/PostGrid.astro"
import Icon from "@/components/ui/Icon.astro"
import { SITE_CONFIG } from "@/config/site"
import { getPosts } from "@/utils/posts"
import { getAuthor } from "@/utils/content"

const posts = await getPosts()
const featurePosts = posts.slice(0, 7)
const author = await getAuthor("default")
const authorData = author?.data

const heroHeadline = SITE_CONFIG.hero.headline
const heroSubheadline = SITE_CONFIG.hero.subheadline

const services = SITE_CONFIG.services ?? []
---

<Layout
  path="/"
  title={heroHeadline}
  description={SITE_CONFIG.description}
  image={featurePosts[0]?.data.heroImage}
>
  <EditorialHero
    author={authorData
      ? {
          name: authorData.name,
          role: authorData.role,
          tagline: authorData.tagline,
          location: authorData.location,
        }
      : undefined}
    heading={heroHeadline}
    subheadline={heroSubheadline}
    ctaLabel={SITE_CONFIG.hero.ctaLabel}
    ctaUrl={SITE_CONFIG.hero.ctaUrl}
    secondaryLabel="Engage us"
    secondaryUrl="/services/"
  />

  <section
    class="mx-auto w-full max-w-6xl px-5 py-16 sm:px-7 sm:py-20 lg:py-24"
    data-pagefind-ignore
    aria-labelledby="services-title"
  >
    <header class="mb-8 flex items-end justify-between gap-4 sm:mb-10">
      <div class="flex flex-col gap-3">
        <span class="section-rule" aria-hidden="true"></span>
        <p class="eyebrow">What we do</p>
        <h2 id="services-title" class="section-title">
          Engagements and frameworks
        </h2>
      </div>
      <a
        class="hidden text-sm underline-offset-4 hover:underline sm:inline-flex sm:items-center sm:gap-1"
        href="/services/"
      >
        <span>Engage us</span>
        <Icon name="arrow-right" class="size-4" />
      </a>
    </header>

    <div class="grid grid-cols-1 gap-x-6 gap-y-6 md:grid-cols-2 lg:grid-cols-4">
      {services.map((service, index) => (
        <ServiceCard
          title={service.title}
          summary={service.summary}
          href={service.href}
          detail={service.detail}
          index={index}
        />
      ))}
    </div>
  </section>

  <section
    class="mx-auto w-full max-w-6xl px-5 pb-16 sm:px-7 sm:pb-20"
    data-pagefind-ignore
    aria-labelledby="latest-title"
  >
    <header class="mb-8 flex items-end justify-between gap-4 sm:mb-10">
      <div class="flex flex-col gap-3">
        <span class="section-rule" aria-hidden="true"></span>
        <p class="eyebrow">Recent work</p>
        <h2 id="latest-title" class="section-title">Latest essays</h2>
      </div>
      <a
        class="inline-flex items-center gap-1 text-sm underline-offset-4 hover:underline"
        href="/posts/"
      >
        <span>See all essays</span>
        <Icon name="arrow-right" class="size-4" />
      </a>
    </header>

    <PostGrid posts={featurePosts} featuredFirst={true} />
  </section>

  {
    authorData ? (
      <section
        class="mx-auto w-full max-w-6xl px-5 pb-20 sm:px-7 sm:pb-24"
        data-pagefind-ignore
        aria-labelledby="profile-title"
      >
        <header class="mb-8 flex items-end justify-between gap-4 sm:mb-10">
          <div class="flex flex-col gap-3">
            <span class="section-rule" aria-hidden="true"></span>
            <p class="eyebrow">About the author</p>
            <h2 id="profile-title" class="section-title">
              Who writes here
            </h2>
          </div>
          <a
            class="inline-flex items-center gap-1 text-sm underline-offset-4 hover:underline"
            href="/about/"
          >
            <span>Read about</span>
            <Icon name="arrow-right" class="size-4" />
          </a>
        </header>
        <ProfileCard author={author} ctaHref="/about/" ctaLabel="Read about" />
      </section>
    ) : null
  }
</Layout>
